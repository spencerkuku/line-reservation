# Frontend Environment Configuration
# 複製此檔案為 .env 並修改相應的值
# ⚠️ PRODUCTION 標記說明：
#    [必須] 安全性或功能要求，production 環境必須修改
#    [建議] 最佳實踐，強烈建議修改
#    [可選] 依需求調整

# 應用程式基本設定
VITE_APP_NAME=LINE Reservation System       # [可選] 應用程式顯示名稱
VITE_APP_VERSION=1.0.0                      # [可選] 版本號
VITE_APP_LOCALE=zh_TW                       # [可選] 預設語言
VITE_APP_FALLBACK_LOCALE=en                 # [可選] 備用語言

# ========== 生產環境設定（PRODUCTION 必須修改以下所有欄位）==========
VITE_APP_URL=https://your-domain.com        # [必須] 必須修改為實際前端域名
VITE_API_BASE_URL=https://your-domain.com/api  # [必須] 必須修改為實際後端 API 域名
VITE_NODE_ENV=production                    # [必須] 必須確保為 production
VITE_DEBUG=false                            # [必須] 必須確保為 false（安全性）
VITE_ENABLE_SECURITY_LOGS=false             # [必須] 必須確保為 false（避免洩露敏感資訊）
VITE_API_TIMEOUT=30000                      # [建議] 建議依網路狀況調整（毫秒）

# 開發環境設定（開發時取消註解，生產環境必須註解掉）
# VITE_APP_URL=http://localhost:5173
# VITE_API_BASE_URL=http://localhost:8000/api
# NODE_ENV=development
# VITE_DEBUG=true