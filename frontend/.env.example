# Frontend Environment Configuration Example
# ==========================================
# Copy this file to .env and modify the values as needed

# Application Information
VITE_APP_NAME="LINE 預約系統"
VITE_APP_VERSION="1.0.0"

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api

# Frontend URLs
VITE_APP_URL=http://localhost:5173
VITE_APP_HOST=localhost
VITE_APP_PORT=5173

# Backend URLs  
VITE_BACKEND_URL=http://localhost:8000
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=8000

# Environment
NODE_ENV=development

# Security Settings
VITE_SECURE_COOKIES=false
VITE_SAME_SITE=lax

# Debug
VITE_DEBUG=true

# Production Example (uncomment and modify for production):
# VITE_API_BASE_URL=https://your-domain.com/api
# VITE_APP_URL=https://your-frontend-domain.com
# VITE_BACKEND_URL=https://your-domain.com
# NODE_ENV=production
# VITE_SECURE_COOKIES=true
# VITE_DEBUG=false

# ngrok Example (for development with ngrok):
# VITE_API_BASE_URL=https://xxxx-xxx-xxx-xxx-xxx.ngrok-free.app/api
# VITE_APP_URL=https://xxxx-xxx-xxx-xxx-xxx.ngrok-free.app
# VITE_BACKEND_URL=https://xxxx-xxx-xxx-xxx-xxx.ngrok-free.app