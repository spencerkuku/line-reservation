# LINE 預約系統前端環境配置
# ==========================================
# 複製此檔案為 .env 並根據實際部署環境修改相應的值

# ==========================================
#  核心配置 (必須配置)
# ==========================================

# API 配置 (後端 API 地址)
VITE_API_BASE_URL=https://your-domain.com/api

# ==========================================
#  部署環境範例配置
# ==========================================

# 本地開發環境範例:
# VITE_API_BASE_URL=http://localhost:8000/api

# 測試環境範例:
# VITE_API_BASE_URL=http://localhost:8001/api

# Docker 環境範例:
# VITE_API_BASE_URL=http://backend:8000/api
