# Backend Environment Configuration Example
# ==========================================
# Copy this file to .env and modify the values as needed
# ⚠️ PRODUCTION 標記說明：
#    [必須] 安全性或功能要求，production 環境必須修改
#    [建議] 最佳實踐，強烈建議修改
#    [可選] 依需求調整

# Application Settings
APP_NAME=LineReservation                    # [可選] 應用程式名稱
APP_ENV=local                               # [必須] 必須修改為 production
APP_KEY=                                    # [必須] 必須執行 php artisan key:generate
APP_DEBUG=true                              # [必須] 必須修改為 false（安全性）
APP_URL=http://localhost:8000               # [必須] 必須修改為實際域名 https://your-domain.com
APP_TIMEZONE=Asia/Taipei                    # [可選] 時區設定

# Frontend URL Settings (for CORS)
FRONTEND_URL=http://localhost:5173          # [必須] 必須修改為實際前端域名 https://your-frontend.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000  # [必須] 必須修改為實際域名列表

# Language Settings
APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_TW

# Performance
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

# Security
BCRYPT_ROUNDS=12                            # [建議] 建議修改為 14 以提升安全性

# Session Configuration
SESSION_DRIVER=database                     # [可選] session 儲存方式
SESSION_LIFETIME=120                        # [可選] session 有效時間（分鐘）
SESSION_DOMAIN=localhost                    # [必須] 必須修改為實際域名（不含 https://）
SESSION_SAME_SITE=lax                       # [建議] 建議維持 lax 或改為 strict

# Laravel Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173  # [必須] 必須修改為實際前端域名（不含協議）

# Logging
LOG_CHANNEL=stack                           # [可選] 日誌通道
LOG_STACK=single                            # [建議] 建議改為 daily 以自動輪替
LOG_DEPRECATIONS_CHANNEL=null               # [可選] 棄用警告通道
LOG_LEVEL=debug                             # [必須] 必須修改為 error 或 warning（安全性）

# Database Configuration
DB_CONNECTION=mysql                         # [可選] 資料庫類型
DB_HOST=127.0.0.1                           # [建議] 建議修改為實際資料庫主機
DB_PORT=3306                                # [可選] 資料庫埠號
DB_DATABASE=line_reservation                # [建議] 建議修改為 production 資料庫名稱
DB_USERNAME=your_username                   # [必須] 必須修改為實際資料庫用戶名（安全性）
DB_PASSWORD=your_password                   # [必須] 必須修改為強密碼（安全性）

# Cache and Queue
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

VITE_APP_NAME="${APP_NAME}"
