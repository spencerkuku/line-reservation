# LINE 預約系統環境配置
# ==========================================
# 複製此檔案為 .env 並根據實際部署環境修改相應的值

# ==========================================
#  核心應用設定 (必須配置)
# ==========================================
APP_NAME="LINE Reservation System"
APP_ENV=production
APP_KEY=base64:YOUR_32_CHARACTER_SECRET_KEY
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Taipei

# 前端 URL 設定 (CORS 和認證必需)
FRONTEND_URL=https://your-frontend-domain.com

# 語言設定
APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=en

# ==========================================
#  資料庫設定 (必須配置)
# ==========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=line_reservation
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ==========================================
#  LINE Bot 設定 (必須配置)
# ==========================================
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# ==========================================
#  認證與安全設定 (必須配置)
# ==========================================
# Sanctum 認證域名 (前端域名)
SANCTUM_STATEFUL_DOMAINS=your-frontend-domain.com

# Session 設定
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ==========================================
#  郵件設定 (必須配置)
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=your_smtp_host
MAIL_PORT=587
MAIL_USERNAME=your_email_username
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
#  日誌系統設定
# ==========================================
LOG_CHANNEL=stack
LOG_STACK=daily,linebot,reservations,customers,api,frontend
LOG_LEVEL=info
LOG_DAILY_DAYS=30

# ==========================================
#  快取設定
# ==========================================
CACHE_STORE=database
QUEUE_CONNECTION=database

# ==========================================
#  部署環境範例配置
# ==========================================

# 本地開發環境範例:
# APP_ENV=local
# APP_DEBUG=true
# APP_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:5173
# DB_PASSWORD=
# MAIL_MAILER=log
# SESSION_SECURE_COOKIE=false

# Docker 部署範例:
# DB_HOST=db
# REDIS_HOST=redis
# MAIL_HOST=mailhog

# 雲端部署範例:
# APP_URL=https://api.your-domain.com
# FRONTEND_URL=https://app.your-domain.com
# DB_HOST=your-rds-endpoint.amazonaws.com
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_DEFAULT_REGION=ap-northeast-1
