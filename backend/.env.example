# Backend Environment Configuration Example
# ==========================================
# Copy this file to .env and modify the values as needed

# Application Settings
APP_NAME=LineReservation
APP_ENV=local
APP_KEY=base64:RlQDjJIOo9BWIo8vOxiy4+e6CeEElJRjy+rqLEFGha8=
APP_DEBUG=true
APP_URL=http://localhost:8000
DOMAIN_URL=http://localhost:8000
APP_TIMEZONE=Asia/Taipei

# Frontend URL Settings (for CORS)
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# API Configuration
API_BASE_URL=http://localhost:8000/api

# Language Settings
APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_TW

# Performance
APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

# Security
BCRYPT_ROUNDS=12

# Session and CSRF Configuration for Cross-Origin
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=false
SESSION_SAME_SITE=none

# CSRF Configuration
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:3000,127.0.0.1:3000,localhost:8000,127.0.0.1:8000
SESSION_COOKIE=laravel_session

# 添加 CSRF 相關配置
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# 資料庫設定
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=line-reservation # 請根據您的資料庫名稱修改
DB_USERNAME=spencer            
DB_PASSWORD=Spencerku123@

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

VITE_APP_NAME="${APP_NAME}"
